void setup() {
  pinMode(LED_RED, OUTPUT);
  pinMode(LED_GREEN, OUTPUT);
  pinMode(BUTTON_UP, INPUT_PULLUP);
  pinMode(BUTTON_DOWN, INPUT_PULLUP);
  pinMode(BUTTON_LEFT, INPUT_PULLUP);
  pinMode(BUTTON_RIGHT, INPUT_PULLUP);
  pinMode(BUTTON_AUX, INPUT_PULLUP);

  lcdBegin();

  setBitmap(logo);
  updateDisplay();
  delay(2000);
  clearDisplay(WHITE);
  updateDisplay();
}

byte relache = true;
byte sel = 0;
byte CLIGNOTANT;
byte modeJeu = 0;

void loop() {
  switch (modeJeu)
  {
    case PARTIE:
      if (sel == 0)
        tetris_loop();
      else
        pong_loop();
      return;
    default:
      break;
  }


  if (((millis() / 500) % 2) == 0)
    CLIGNOTANT = WHITE;
  else
    CLIGNOTANT = BLACK;

  clearDisplay(WHITE);
  setStr("Tetris", 20, 15, BLACK);
  setStr("Pong", 20, 25, BLACK);

  if (sel == 0)
    setStr("Tetris", 20, 15, CLIGNOTANT);
  else
    setStr("Pong", 20, 25, CLIGNOTANT);

  updateDisplay();


  if (!touche())
  {
    relache = true;
  }

  if (toucheAux())
  {
    modeJeu = PARTIE;
    if (sel == 0)
      tetris_setup();
    else
      pong_setup();
    updateDisplay();
  }

  if (relache && toucheHaut() && sel > 0)
    sel--;

  if (relache && toucheBas() && sel < 2)
    sel++;

  if (touche())
  {
    relache = false;
  }
}
